# --- Optional: Super-Admin nur über Umgebungsvariablen (kein Eintrag in MongoDB nötig) ---
# Wenn SUPERADMIN_EMAIL gesetzt ist, gilt für genau diese E-Mail NUR dieses Passwort
# (kein Login über denselben User in der Datenbank).
# Passwort nur sicher hinterlegen; .env.local niemals committen.
SUPERADMIN_EMAIL=admin@deine-firma.de
SUPERADMIN_PASSWORD=hier_ein_starkes_passwort
# Optional: Anzeigename in der Session
SUPERADMIN_NAME=Super Admin

# NEXTAUTH_SECRET=...
# NEXTAUTH_URL=http://localhost:3000
# MONGODB_URI=...
