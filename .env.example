# Kopieren nach .env.local und Werte anpassen. Nicht committen.
# Typisierung / Validierung: lib/config.ts (export appConfig)

# --- Pflicht für Betrieb (lokal & Produktion) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
NEXTAUTH_SECRET=mindestens_32_zeichen_zufaellig_generieren
# Öffentliche App-URL (Einladungslinks, Redirects)
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: Super-Admin ohne MongoDB-User ---
# Beide müssen gesetzt sein, sonst wird der Block ignoriert (Warnung im Log).
SUPERADMIN_EMAIL=admin@deine-firma.de
SUPERADMIN_PASSWORD=hier_ein_starkes_passwort
SUPERADMIN_NAME=Super Admin

# --- E-Mail (Einladungen / Transaktionsmail, siehe lib/mailer.ts) ---
# Es wird das erste gesetzte Alias pro Rolle genutzt (z. B. EMAIL_HOST oder SMTP_HOST).
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=
# EMAIL_SECURE=false
# EMAIL_REPLY_TO=

# --- MinIO / S3 (Lager-Bilder, Projekt-Dokumente) ---
# MINIO_ENDPOINT=127.0.0.1
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# Alternativ: MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# MINIO_BUCKET=project-documents
# MINIO_PUBLIC_URL=
# MINIO_PATH_STYLE=true
# MINIO_REGION=

# --- Sonstiges ---
# MAX_UPLOAD_SIZE_BYTES=52428800
# NEXT_PUBLIC_WS_URL=
# WS_PORT=3001
